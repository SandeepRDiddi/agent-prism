PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# ── SSO / OIDC (optional — leave blank to disable SSO button) ────────────────
# Works with any OIDC-compliant IDP: Keycloak, Okta, Azure AD, Auth0, Dex, etc.
# OIDC_ISSUER=https://your-idp.example.com/realms/your-realm
# OIDC_CLIENT_ID=agent-prism
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://agent-prism.onrender.com/auth/sso/callback
# OIDC_DEFAULT_TENANT_ID=   # Optional: auto-provision SSO users into this tenant.
#                           # If unset, auto-provisions into the single active tenant.
#                           # Required when multiple tenants exist.
# SSO_ONLY=true             # Set to true to hide password login and show only SSO (enterprise).

# ── Admin secret — MUST be changed before production deployment ───────────────
ACP_ADMIN_SECRET=change-me-before-production
STORAGE_BACKEND=file

# ── ROI Dashboard auth (required in production, optional in dev) ──────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

# ── Encryption — REQUIRED in production ──────────────────────────────────────
# 64-char hex string (32 bytes). Encrypts connector API keys at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this key makes existing encrypted connector keys unreadable.
ENCRYPTION_KEY=

# ── Security & rate limiting ──────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Wildcard (*) is NOT permitted.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Max request body size in bytes (default: 1MB)
MAX_BODY_BYTES=1048576

# Max requests per tenant per minute on authenticated endpoints (default: 300)
RATE_LIMIT_REQUESTS_PER_MINUTE=300

# Gateway upstream timeout in milliseconds (default: 30s). Override per provider.
GATEWAY_TIMEOUT_MS=30000
# GATEWAY_TIMEOUT_ANTHROPIC_MS=30000
# GATEWAY_TIMEOUT_OPENAI_MS=30000
# GATEWAY_TIMEOUT_AZURE_MS=60000

# Graceful shutdown drain timeout in milliseconds (default: 10s)
SHUTDOWN_TIMEOUT_MS=10000

# ── Platform API keys (used to determine "connected" status in dashboard) ─────
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# ── Webhook signing secrets (optional — if omitted, signatures are not verified)
CLAUDE_WEBHOOK_SECRET=
COPILOT_WEBHOOK_SECRET=

# ── Production storage ────────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/agent_control_plane

# Postgres connection pool tuning (defaults suit most deployments)
# DB_POOL_MAX=20               # Max connections. Start here; raise after load testing.
# DB_POOL_MIN=2                # Keep 2 connections warm to absorb burst traffic.
# DB_IDLE_TIMEOUT_MS=30000     # Release idle connections after 30s.
# DB_CONNECTION_TIMEOUT_MS=5000 # Fail fast (5s) when pool is exhausted — never hang.
# DB_STATEMENT_TIMEOUT_MS=30000 # Kill runaway queries after 30s.
# DB_SSL=true                  # Required for Render, RDS, Supabase, Neon, Azure.
# DB_SSL_REJECT_UNAUTHORIZED=false  # false = accept self-signed certs (Render/Neon default)
                                     # true  = strict cert validation (RDS with cert bundle)

# ── Cluster & scale ───────────────────────────────────────────────────────────
# Number of worker processes (npm run cluster). Defaults to os.cpus().length.
# CLUSTER_WORKERS=4

# ── DB migrations ─────────────────────────────────────────────────────────────
# Auto-run pending migrations at server startup (Postgres only).
# Requires DATABASE_URL. Safe to enable — migrations are idempotent.
# RUN_MIGRATIONS_ON_STARTUP=true

# ── Data retention ────────────────────────────────────────────────────────────
# Delete agent runs and prompt captures older than N days. 0 = keep forever.
# DATA_RETENTION_DAYS=90

# ── Circuit breakers ──────────────────────────────────────────────────────────
# Trip circuit after N consecutive upstream failures (default: 5).
# CB_FAILURE_THRESHOLD=5
# Require N successes in HALF_OPEN to close circuit (default: 2).
# CB_SUCCESS_THRESHOLD=2
# Milliseconds before attempting recovery from OPEN state (default: 30s).
# CB_RESET_TIMEOUT_MS=30000
